# Workable
WORKABLE_SUBDOMAIN=rditrials
WORKABLE_TOKEN=
WORKABLE_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Cron auth (Vercel)
CRON_SECRET=

# Clerk (Vercel Marketplace: vercel integration add clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Integrations (phase 2+)
VIDEOASK_API_KEY=
VIDEOASK_WEBHOOK_SECRET=
CALENDLY_TOKEN=
FIREFLIES_API_KEY=

# Commute lookup — Geoapify free tier (3,000 credits/day, no credit card).
# Get a key: https://myprojects.geoapify.com/  → create project → API Keys.
# Optional: when unset, the candidate commute falls back to Claude's estimate.
GEOAPIFY_API_KEY=
# Office candidates commute to (geocoded by Geoapify). Defaults to Van Nuys.
RDI_OFFICE_ADDRESS=Van Nuys, CA, USA

# Talent Radar — people/contact enrichment providers (both optional).
# When unset, that provider is skipped; CSV upload and manual add still work.
# Seamless.AI: https://www.seamless.ai/  ·  Apollo: https://www.apollo.io/
SEAMLESS_API_KEY=
APOLLO_API_KEY=
# Public origin used to build outbound unsubscribe links. On Vercel this can be
# left blank (VERCEL_URL is used). Set explicitly for a custom domain.
RADAR_PUBLIC_URL=
