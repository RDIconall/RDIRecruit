# Workable
WORKABLE_SUBDOMAIN=rditrials
WORKABLE_TOKEN=
WORKABLE_WEBHOOK_SECRET=
# Member id credited with candidate write actions (move / disqualify / revert /
# comment). REQUIRED for those writes — without it they skip gracefully (logged,
# no error). Find yours: GET https://rditrials.workable.com/spi/v3/members with
# your WORKABLE_TOKEN and copy the `id` of the acting member.
WORKABLE_MEMBER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Cron auth (Vercel)
CRON_SECRET=

# Outbound email — daily applicant summary, sent over SMTP from your own inbox.
# Defaults target Google Workspace / Gmail: create an app password
# (https://myaccount.google.com/apppasswords — requires 2-step verification),
# then set SMTP_USER to your address and SMTP_PASS to that app password.
# All optional: when unset the summary cron still runs but skips the send.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Optional "from" override; defaults to SMTP_USER. e.g. "RDIRecruit <you@rditrials.com>".
SUMMARY_EMAIL_FROM=
# Who gets the summary — comma-separated (you + Lara).
SUMMARY_EMAIL_TO=

# Clerk (Vercel Marketplace: vercel integration add clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Integrations (phase 2+)
VIDEOASK_API_KEY=
VIDEOASK_WEBHOOK_SECRET=
CALENDLY_TOKEN=
FIREFLIES_API_KEY=

# Commute lookup — Geoapify free tier (3,000 credits/day, no credit card).
# Get a key: https://myprojects.geoapify.com/  → create project → API Keys.
# Optional: when unset, the candidate commute falls back to Claude's estimate.
GEOAPIFY_API_KEY=
# Office candidates commute to (geocoded by Geoapify). Defaults to Van Nuys.
RDI_OFFICE_ADDRESS=Van Nuys, CA, USA

# Talent Radar — people/contact enrichment providers (both optional).
# When unset, that provider is skipped; CSV upload and manual add still work.
# Seamless.AI: https://www.seamless.ai/  ·  Apollo: https://www.apollo.io/
SEAMLESS_API_KEY=
APOLLO_API_KEY=
# Public origin used to build outbound unsubscribe links. On Vercel this can be
# left blank (VERCEL_URL is used). Set explicitly for a custom domain.
RADAR_PUBLIC_URL=
